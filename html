<!-- Selam AI Chatbot -->
<div class="chatbot-button" id="chatbotButton">
  <img src="https://via.placeholder.com/56/2c5a5a/ffffff?text=🌿" alt="Selam" class="selam-avatar">
</div>

<div class="chatbot-window" id="chatbotWindow">
  <div class="chatbot-header">
    <h3>
      <img src="https://via.placeholder.com/32/2c5a5a/ffffff?text=🌿" alt="Selam" class="header-avatar">
      Selam AI
      <span class="ai-badge">✨ Peace Guide</span>
    </h3>
    <button class="close-chat" id="closeChat">×</button>
  </div>
  <div class="chat-messages" id="chatMessages">
    <div class="message bot">
      <img src="https://via.placeholder.com/32/2c5a5a/ffffff?text=🌿" alt="Selam" class="bot-avatar">
      <div class="message-content">✨ Selam! I'm Selam, your Peace Guide. I'm here to listen, support, and help you share peace. What's on your heart today? 💫</div>
    </div>
  </div>
  <div class="quick-replies">
    <button class="quick-reply" data-msg="I want to share a peace message">🕊️ Share Peace</button>
    <button class="quick-reply" data-msg="Tell me about courses">📚 Courses</button>
    <button class="quick-reply" data-msg="Give me a peace quote">💫 Peace Quote</button>
    <button class="quick-reply" data-msg="I need emotional support">🌿 Support</button>
  </div>
  <div class="chat-input-area">
    <textarea class="chat-input" id="chatInput" placeholder="Type your message..." rows="1"></textarea>
    <button class="send-btn" id="sendBtn">Send</button>
  </div>
  <div class="api-warning">🌟 Selam AI — Your peaceful companion. Always here for you.</div>
</div>

<script>
  // ========== PEACE SUBMISSIONS ==========
  let submissions = JSON.parse(localStorage.getItem('peaceSubmissions') || '[]');
  
  // Character counter
  document.querySelectorAll('.form-textarea').forEach(textarea => {
    const counter = textarea.parentElement.querySelector('.char-count');
    textarea.addEventListener('input', function() {
      counter.textContent = `${this.value.length} / 1000`;
    });
  });
  
  // Handle submission
  function handleSubmission(event, category) {
    event.preventDefault();
    const form = event.target;
    const name = form.querySelector('.form-input').value.trim() || 'Anonymous';
    const message = form.querySelector('.form-textarea').value.trim();
    const feedback = form.querySelector('.submission-feedback');
    
    if (!message) {
      feedback.textContent = '💌 Please share your message before submitting.';
      feedback.style.color = '#c97e2c';
      return;
    }
    
    const submission = {
      id: Date.now(),
      category,
      name,
      message,
      timestamp: new Date().toLocaleString()
    };
    
    submissions.unshift(submission);
    if (submissions.length > 20) submissions.pop();
    localStorage.setItem('peaceSubmissions', JSON.stringify(submissions));
    
    form.querySelector('.form-input').value = '';
    form.querySelector('.form-textarea').value = '';
    feedback.textContent = '✨ Your peace offering has been saved! It appears in Recent Lights. ✨';
    feedback.style.color = '#4a9e6e';
    setTimeout(() => feedback.textContent = '', 4000);
    updateRecentLights();
  }
  
  function updateRecentLights() {
    const container = document.getElementById('recent-lights-container');
    if (!container) return;
    
    if (submissions.length === 0) {
      container.innerHTML = '<div class="light-item">✨ Be the first to share peace!</div>';
      return;
    }
    
    const recent = submissions.slice(0, 5);
    container.innerHTML = recent.map(sub => {
      const preview = sub.message.length > 50 ? sub.message.substring(0, 50) + '...' : sub.message;
      return `<div class="light-item">${getIconForCategory(sub.category)} <strong>${escapeHtml(sub.name)}</strong>: “${escapeHtml(preview)}”</div>`;
    }).join('');
  }
  
  function getIconForCategory(category) {
    const icons = {
      'Personal': '👤',
      'Couple': '💑',
      'Family': '👨👩👧👦',
      'Group': '👥',
      'Time Capsule': '⭐'
    };
    return icons[category] || '🕊️';
  }
  
  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }
  
  function viewAllSubmissions() {
    if (submissions.length === 0) {
      alert('No submissions yet. Be the first to share peace!');
    } else {
      let message = `📖 ${submissions.length} peace messages shared:\n\n`;
      submissions.forEach((sub, i) => {
        message += `${i+1}. [${sub.category}] ${sub.name}: ${sub.message.substring(0, 80)}${sub.message.length > 80 ? '...' : ''}\n`;
      });
      alert(message.length > 2000 ? message.substring(0, 2000) + '\n\n... and more' : message);
      console.table(submissions);
    }
  }
  
  updateRecentLights();
  
  // ========== SELAM AI CHATBOT ==========
  function guideResponse(userMessage) {
    const msg = userMessage.toLowerCase();
    
    if (msg.includes('share') || msg.includes('peace message')) {
      return "🕊️ I'd love to help you share peace. Choose a card above (Personal, Couple, Family, Group, or Time Capsule) and write what's in your heart. Your words become light for others.";
    } else if (msg.includes('course') || msg.includes('learn')) {
      return "📚 We have 3 courses: Peacebuilding 101 (65% complete), Global Peace Initiatives (30%), and Mediation & Dialogue (90%). Which would you like to know more about?";
    } else if (msg.includes('quote')) {
      const quotes = [
        "🕊️ 'Peace is not absence of conflict, it is the ability to handle conflict by peaceful means.' — Ronald Reagan",
        "✨ 'We do not wait for peace. We make it.' — Book for Peace",
        "🌱 'When the power of love overcomes the love of power, the world will know peace.' — Jimi Hendrix",
        "💫 'Selam begins within. Nurture your heart, and peace will follow.' — Selam AI"
      ];
      return quotes[Math.floor(Math.random() * quotes.length)];
    } else if (msg.includes('support') || msg.includes('sad') || msg.includes('help')) {
      return "🌿 I hear you. Take a gentle breath. Would you like to share what's on your mind? Writing can be healing. I'm here to listen.";
    } else if (msg.includes('magazine')) {
      return "📖 Our latest magazine features Stories of Hope from Tigray, The Art of Nonviolence, and Youth Leading Change. Would you like a summary of any article?";
    } else {
      return "🙏 Thank you for reaching out. Would you like to share a peace message, explore our courses, or hear an inspiring quote? I'm here for you.";
    }
  }
  
  // Chat UI
  const chatWindow = document.getElementById('chatbotWindow');
  const chatButton = document.getElementById('chatbotButton');
  const closeChat = document.getElementById('closeChat');
  const chatMessages = document.getElementById('chatMessages');
  const chatInput = document.getElementById('chatInput');
  const sendBtn = document.getElementById('sendBtn');
  
  chatButton.addEventListener('click', () => chatWindow.classList.add('open'));
  closeChat.addEventListener('click', () => chatWindow.classList.remove('open'));
  
  function addMessage(text, isUser) {
    const div = document.createElement('div');
    div.className = `message ${isUser ? 'user' : 'bot'}`;
    
    if (!isUser) {
      div.innerHTML = `<img src="https://via.placeholder.com/32/2c5a5a/ffffff?text=🌿" class="bot-avatar"><div class="message-content">${text}</div>`;
    } else {
      div.innerHTML = `<div class="message-content">${text}</div>`;
    }
    
    chatMessages.appendChild(div);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  
  function showTyping() {
    const typingDiv = document.createElement('div');
    typingDiv.className = 'message bot';
    typingDiv.id = 'typingIndicator';
    typingDiv.innerHTML = `<img src="https://via.placeholder.com/32/2c5a5a/ffffff?text=🌿" class="bot-avatar"><div class="typing-indicator"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span> Selam is listening...</div>`;
    chatMessages.appendChild(typingDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
  
  function removeTyping() {
    const typing = document.getElementById('typingIndicator');
    if (typing) typing.remove();
  }
  
  async function sendMessage() {
    const message = chatInput.value.trim();
    if (!message) return;
    
    addMessage(message, true);
    chatInput.value = '';
    
    showTyping();
    setTimeout(() => {
      removeTyping();
      addMessage(guideResponse(message), false);
    }, 600);
  }
  
  sendBtn.addEventListener('click', sendMessage);
  chatInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });
  
  // Quick reply buttons
  document.querySelectorAll('.quick-reply').forEach(btn => {
    btn.addEventListener('click', () => {
      chatInput.value = btn.getAttribute('data-msg');
      sendMessage();
    });
  });
  
  // Auto-resize textarea
  chatInput.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 80) + 'px';
  });
</script>
</body>
